---
interface Props {
  titulo: string;
  urlRelativa: string;
}

const { titulo, urlRelativa } = Astro.props;
const base = 'https://mesaconciencia.com';
const urlCompleta = `${base}${urlRelativa}`;
const urlCod = encodeURIComponent(urlCompleta);
const tituloCod = encodeURIComponent(titulo);
---

<div class="compartir">
  <span class="compartir-label">Compartir</span>
  <ul class="compartir-lista">
    <li>
      <a
        href={`https://wa.me/?text=${tituloCod}%20${urlCod}`}
        target="_blank"
        rel="noopener noreferrer"
        class="compartir-btn compartir-wa"
        aria-label="Compartir por WhatsApp"
        title="WhatsApp"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12.002 2C6.477 2 2 6.477 2 12.002c0 1.769.463 3.484 1.343 4.992L2.046 22l5.148-1.346A9.96 9.96 0 0012.002 22c5.523 0 9.998-4.477 9.998-9.998C22 6.477 17.525 2 12.002 2zm0 18.18a8.152 8.152 0 01-4.157-1.139l-.298-.177-3.056.799.815-2.977-.194-.306A8.163 8.163 0 013.818 12c0-4.516 3.668-8.182 8.184-8.182 4.515 0 8.182 3.666 8.182 8.182 0 4.515-3.667 8.18-8.182 8.18z"/>
        </svg>
      </a>
    </li>
    <li>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${urlCod}`}
        target="_blank"
        rel="noopener noreferrer"
        class="compartir-btn compartir-fb"
        aria-label="Compartir en Facebook"
        title="Facebook"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073C24 5.406 18.627 0 12 0S0 5.406 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.971h-1.514c-1.491 0-1.956.93-1.956 1.875v2.254h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
        </svg>
      </a>
    </li>
    <li>
      <a
        href={`https://twitter.com/intent/tweet?url=${urlCod}&text=${tituloCod}`}
        target="_blank"
        rel="noopener noreferrer"
        class="compartir-btn compartir-x"
        aria-label="Compartir en X (Twitter)"
        title="X"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </li>
    <li>
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${urlCod}`}
        target="_blank"
        rel="noopener noreferrer"
        class="compartir-btn compartir-li"
        aria-label="Compartir en LinkedIn"
        title="LinkedIn"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </li>
  </ul>
</div>

<style>
  .compartir {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--borde);
  }

  .compartir-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--texto-suave);
    white-space: nowrap;
  }

  .compartir-lista {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .compartir-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: white !important;
    text-decoration: none !important;
    transition: opacity 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  .compartir-btn:hover {
    opacity: 0.85;
    transform: scale(1.1);
    text-decoration: none !important;
  }

  .compartir-wa  { background: #25d366; }
  .compartir-fb  { background: #1877f2; }
  .compartir-x   { background: #000000; }
  .compartir-li  { background: #0a66c2; }
</style>
