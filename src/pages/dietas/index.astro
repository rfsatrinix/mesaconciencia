---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entradas = await getCollection('dietas', ({ data }) => !data.draft);
---

<Layout
  title="Dietas"
  description="Dietas terapéuticas, populares y peligrosas analizadas con rigor científico. Sin marketing ni promesas vacías."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <span>Dietas</span>
      </nav>
      <h1>Dietas</h1>
      <p class="intro">
        Dieta keto, mediterránea, vegana, paleo, detox y muchas más.
        Analizadas con evidencia científica, sin intereses comerciales y con especial atención a las que pueden ser peligrosas.
      </p>
    </div>

    {
      entradas.length > 0 ? (
        <div class="grid-articulos seccion">
          {entradas.map((e) => (
            <a href={`/dietas/${e.id}`} class="tarjeta-articulo tarjeta">
              <div class="tarjeta-articulo-inner">
                {e.data.tipo && (
                  <span
                    class="etiqueta"
                    style={`margin-bottom: 0.75rem; display: inline-block; ${e.data.tipo === 'peligrosa' ? 'background: #fee2e2; color: #991b1b;' : ''}`}
                  >
                    {e.data.tipo}
                  </span>
                )}
                <h2>{e.data.title}</h2>
                <p>{e.data.description}</p>
                <span class="leer-mas">Leer análisis →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )
    }
  </div>
</Layout>
