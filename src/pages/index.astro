---
import Layout from '../layouts/Layout.astro';

const categorias = [
  {
    nombre: 'Nutrición',
    href: '/nutricion',
    icono: '🧬',
    desc: 'Proteínas, carbohidratos, grasas, vitaminas, minerales y fibra. Lo que tu cuerpo necesita y por qué.',
  },
  {
    nombre: 'Alimentos',
    href: '/alimentos',
    icono: '🥦',
    desc: 'Frutas, verduras, carnes, legumbres y mucho más. Propiedades nutricionales con evidencia científica.',
  },
  {
    nombre: 'Recetas',
    href: '/recetas',
    icono: '🍲',
    desc: 'Recetas saludables y equilibradas para desayunos, comidas, cenas y postres.',
  },
  {
    nombre: 'Dietas',
    href: '/dietas',
    icono: '📋',
    desc: 'Dietas populares, terapéuticas y peligrosas analizadas sin filtros ni marketing.',
  },
  {
    nombre: 'Salud',
    href: '/salud',
    icono: '❤️',
    desc: 'Diabetes, colesterol, hipertensión, enfermedades autoinmunes. La alimentación como herramienta.',
  },
  {
    nombre: 'Plantas',
    href: '/plantas',
    icono: '🌿',
    desc: 'Plantas medicinales. Qué dice la evidencia científica sobre sus propiedades reales.',
  },
];
---

<Layout
  title="Nutrición con rigor. Sin dogmas."
  description="Mesa con Ciencia: información nutricional con respaldo científico y un lenguaje que entiende cualquier persona. Elaborado por un dietista titulado."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="etiqueta">Elaborado por un dietista titulado</span>
      <h1>Nutrición con rigor.<br />Sin dogmas.</h1>
      <p class="hero-desc">
        Información nutricional con respaldo científico y un lenguaje que entiende cualquier persona.
        Sin modas, sin gurús, sin intereses.
      </p>
      <div class="hero-ctas">
        <a href="/nutricion" class="btn btn-primario">Explorar nutrientes</a>
        <a href="/alimentos" class="btn btn-contorno">Ver alimentos</a>
      </div>
    </div>
  </section>

  <!-- Categorías -->
  <section class="seccion">
    <div class="container">
      <h2 class="titulo-seccion">¿Qué quieres consultar?</h2>
      <p class="subtitulo-seccion">
        Todo el contenido está respaldado por referencias a estudios científicos publicados.
      </p>
      <div class="grid-categorias">
        {
          categorias.map((cat) => (
            <a href={cat.href} class="tarjeta-categoria tarjeta">
              <div class="tarjeta-categoria-inner">
                <span class="icono-cat" aria-hidden="true">{cat.icono}</span>
                <h3>{cat.nombre}</h3>
                <p>{cat.desc}</p>
                <span class="leer-mas">Ver {cat.nombre.toLowerCase()} →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Por qué Mesa con Ciencia -->
  <section class="seccion seccion-porque">
    <div class="container">
      <div class="porque-grid">
        <div class="porque-texto">
          <h2>¿Por qué Mesa con Ciencia?</h2>
          <p>
            En internet hay dos tipos de contenido sobre nutrición: el que vende y el que aburre.
            El primero tiene audiencia pero no tiene rigor. El segundo tiene rigor pero no llega a la gente.
          </p>
          <p>
            Este proyecto nació para cubrir ese hueco: información nutricional con respaldo científico,
            escrita para cualquier persona, sin necesidad de un máster en bioquímica para entenderla.
          </p>
          <a href="/sobre-mi" class="btn btn-contorno" style="margin-top: 1.5rem;">Conoce al autor →</a>
        </div>
        <div class="porque-pilares">
          <div class="pilar">
            <strong>Referencias bibliográficas</strong>
            <p>Cada afirmación está respaldada por estudios publicados en revistas científicas.</p>
          </div>
          <div class="pilar">
            <strong>Dietista titulado</strong>
            <p>El autor tiene estudios superiores reglados de dietética.</p>
          </div>
          <div class="pilar">
            <strong>Sin intereses comerciales</strong>
            <p>Sin laboratorios detrás. Sin suplementos que vender. Solo información honesta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4.5rem;
    background: linear-gradient(160deg, var(--bg-alt) 0%, var(--bg) 55%);
  }
  .hero .etiqueta {
    margin-bottom: 1.25rem;
    display: inline-block;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 1rem 0 1.25rem;
    line-height: 1.1;
    max-width: 560px;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--texto-suave);
    max-width: 520px;
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }
  .hero-ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* Grid categorías */
  .grid-categorias {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1.25rem;
  }

  .tarjeta-categoria {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }
  .tarjeta-categoria-inner {
    padding: 1.75rem;
  }
  .icono-cat {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }
  .tarjeta-categoria h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .tarjeta-categoria p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    margin-bottom: 1rem;
    line-height: 1.55;
  }

  /* Por qué */
  .seccion-porque {
    background: var(--bg-alt);
  }
  .porque-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .porque-texto h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1rem;
  }
  .porque-texto p {
    color: var(--texto-suave);
    margin-bottom: 0.875rem;
    line-height: 1.7;
  }

  .porque-pilares {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pilar {
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border-radius: var(--radio);
    border: 1px solid var(--borde);
  }
  .pilar strong {
    display: block;
    margin-bottom: 0.3rem;
    color: var(--verde);
    font-size: 0.95rem;
  }
  .pilar p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 3rem;
    }
    .porque-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
