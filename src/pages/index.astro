---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const COLECCIONES = ['alimentos', 'nutricion', 'dietas', 'salud', 'plantas', 'recetas'] as const;

type Entrada = { id: string; coleccion: string; data: { title: string; description?: string; date?: Date; draft: boolean } };

const articulos: Entrada[] = (
  await Promise.all(
    COLECCIONES.map(async (col) => {
      const entradas = await getCollection(col, ({ data }) => !data.draft);
      return entradas.map(e => ({ ...e, coleccion: col })) as Entrada[];
    })
  )
).flat().sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)).slice(0, 9);

const etiquetas: Record<string, string> = {
  alimentos: 'Alimentos',
  nutricion: 'Nutrición',
  dietas:    'Dietas',
  salud:     'Salud',
  plantas:   'Plantas',
  recetas:   'Recetas',
};
---

<Layout
  title="Mesa con Ciencia"
  description="Nutrición explicada de forma sencilla para el común de los mortales."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-col">
        <h1>«Que tu medicina sea tu alimento y el alimento tu medicina»<span class="cita-autor"> — Hipócrates</span></h1>
        <p class="hero-desc">
          Nutrición explicada de forma sencilla para el común de los mortales.
        </p>
      </div>
    </div>
  </section>

  <!-- Últimos artículos -->
  <section class="seccion">
    <div class="container">
      <div class="hero-col">
        <h2 class="titulo-seccion">Últimos artículos</h2>
        <div class="grid-articulos-home">
          {articulos.map((art) => (
            <a href={`/${art.coleccion}/${art.id}`} class="tarjeta tarjeta-home">
              <div class="tarjeta-home-inner">
                <span class="etiqueta">{etiquetas[art.coleccion]}</span>
                <h3>{art.data.title}</h3>
                {art.data.description && <p>{art.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Por qué Mesa con Ciencia -->
  <section class="seccion seccion-porque">
    <div class="container">
      <div class="hero-col porque-texto">
            <h2>¿Por qué Mesa con Ciencia?</h2>
            <p>
              En dietética hay mucho ruido: modas que van y vienen, afirmaciones sin base
              y controversias que no lo son.
            </p>
            <p>
              Quiero que Mesa con Ciencia esté escrito con rigor. Si la ciencia evoluciona,
              si la evidencia cambia, el contenido también.
            </p>
            <a href="/sobre-mi" class="btn btn-contorno" style="margin-top: 1.5rem;">Conoce a la autora →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4.5rem;
    background: linear-gradient(160deg, var(--bg-alt) 0%, var(--bg) 55%);
  }
  .hero-col {
    max-width: 960px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: clamp(1.2rem, 2.3vw, 1.7rem);
    font-style: italic;
    margin: 0 0 1.25rem;
    line-height: 1.4;
  }
  .cita-autor {
    font-style: normal;
    color: var(--texto-suave);
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--texto-suave);
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }

  /* Grid artículos */
  .grid-articulos-home {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .tarjeta-home {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }
  .tarjeta-home-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
  }
  .tarjeta-home h3 {
    font-size: 1.05rem;
    margin: 0;
    color: var(--texto);
  }
  .tarjeta-home p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .tarjeta-home .leer-mas {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--verde);
    margin-top: 0.25rem;
  }

  /* Por qué */
  .seccion-porque {
  }
  .porque-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .porque-texto {
    background: var(--blanco);
    border: 1px solid var(--borde);
    border-radius: var(--radio);
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .porque-texto .btn {
    align-self: flex-end;
  }
  .porque-texto h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1rem;
  }
  .porque-texto p {
    color: var(--texto-suave);
    margin-bottom: 0.875rem;
    line-height: 1.7;
  }
  .porque-pilares {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pilar {
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border-radius: var(--radio);
    border: 1px solid var(--borde);
  }
  .pilar strong {
    display: block;
    margin-bottom: 0.3rem;
    color: var(--verde);
    font-size: 0.95rem;
  }
  .pilar p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 3rem;
    }
    .grid-articulos-home {
      grid-template-columns: repeat(2, 1fr);
    }
    .porque-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .grid-articulos-home {
      grid-template-columns: 1fr;
    }
    .porque-texto {
      padding: 1.5rem;
    }
  }
</style>
