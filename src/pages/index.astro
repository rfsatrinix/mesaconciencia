---
import Layout from '../layouts/Layout.astro';

const categorias = [
  {
    nombre: 'Nutrición',
    href: '/nutricion',
    icono: '🧬',
    desc: 'Proteínas, carbohidratos, grasas, vitaminas, minerales y fibra. Lo que tu cuerpo necesita y por qué.',
  },
  {
    nombre: 'Alimentos',
    href: '/alimentos',
    icono: '🥦',
    desc: 'Frutas, verduras, carnes, legumbres y mucho más. Propiedades nutricionales con evidencia científica.',
  },
  {
    nombre: 'Recetas',
    href: '/recetas',
    icono: '🍲',
    desc: 'Recetas saludables y equilibradas para desayunos, comidas, cenas y postres.',
  },
  {
    nombre: 'Dietas',
    href: '/dietas',
    icono: '📋',
    desc: 'Dietas populares, terapéuticas y peligrosas analizadas sin filtros ni marketing.',
  },
  {
    nombre: 'Salud',
    href: '/salud',
    icono: '❤️',
    desc: 'Diabetes, colesterol, hipertensión, enfermedades autoinmunes. La alimentación como herramienta.',
  },
  {
    nombre: 'Plantas',
    href: '/plantas',
    icono: '🌿',
    desc: 'Plantas medicinales. Qué dice la evidencia científica sobre sus propiedades reales.',
  },
];
---

<Layout
  title="Mesa con Ciencia"
  description="Nutrición explicada de forma sencilla para el común de los mortales."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-col">
        <h1>«Que tu medicina sea tu alimento y el alimento tu medicina»<span class="cita-autor"> — Hipócrates</span></h1>
        <p class="hero-desc">
          Nutrición explicada de forma sencilla para el común de los mortales.
        </p>
      </div>
    </div>
  </section>

  <!-- Categorías -->
  <section class="seccion">
    <div class="container">
      <div class="hero-col">
        <h2 class="titulo-seccion">¿Qué quieres consultar?</h2>
        <div class="grid-categorias">
          {
            categorias.map((cat) => (
              <a href={cat.href} class="tarjeta-categoria tarjeta">
                <div class="tarjeta-categoria-inner">
                  <span class="icono-cat" aria-hidden="true">{cat.icono}</span>
                  <h3>{cat.nombre}</h3>
                  <p>{cat.desc}</p>
                  <span class="leer-mas">Ver {cat.nombre.toLowerCase()} →</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Por qué Mesa con Ciencia -->
  <section class="seccion seccion-porque">
    <div class="container">
      <div class="hero-col">
      <div class="porque-grid">
        <div class="porque-texto">
          <h2>¿Por qué Mesa con Ciencia?</h2>
          <p>
            En dietética hay mucho ruido: modas que van y vienen, afirmaciones sin base
            y controversias que no lo son.
          </p>
          <p>
            Mesa con Ciencia está escrito con el máximo rigor posible.
            Cada artículo cita los estudios en que se basa, para que puedas
            contrastar lo que lees.
          </p>
          <a href="/sobre-mi" class="btn btn-contorno" style="margin-top: 1.5rem;">Conoce a la autora →</a>
        </div>
        <div class="porque-pilares">
          <div class="pilar">
            <strong>Dietista titulada</strong>
            <p>Autora con estudios superiores reglados de dietética.</p>
          </div>
          <div class="pilar">
            <strong>Sin dogmas</strong>
            <p>La ciencia evoluciona. Si la evidencia cambia, el contenido también.</p>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4.5rem;
    background: linear-gradient(160deg, var(--bg-alt) 0%, var(--bg) 55%);
  }
  .hero .etiqueta {
    margin-bottom: 1.25rem;
    display: inline-block;
  }
  .hero-col {
    max-width: 960px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: clamp(1.2rem, 2.3vw, 1.7rem);
    font-style: italic;
    margin: 0 0 1.25rem;
    line-height: 1.4;
  }
  .cita-autor {
    font-style: normal;
    color: var(--texto-suave);
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--texto-suave);
    max-width: none;
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }
  .hero-ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* Grid categorías */
  .grid-categorias {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .tarjeta-categoria {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }
  .tarjeta-categoria-inner {
    padding: 1.75rem;
  }
  .icono-cat {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }
  .tarjeta-categoria h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .tarjeta-categoria p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    margin-bottom: 1rem;
    line-height: 1.55;
  }

  /* Por qué */
  .seccion-porque {
    background: var(--bg-alt);
  }
  .porque-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .porque-texto h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1rem;
  }
  .porque-texto p {
    color: var(--texto-suave);
    margin-bottom: 0.875rem;
    line-height: 1.7;
  }

  .porque-pilares {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pilar {
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border-radius: var(--radio);
    border: 1px solid var(--borde);
  }
  .pilar strong {
    display: block;
    margin-bottom: 0.3rem;
    color: var(--verde);
    font-size: 0.95rem;
  }
  .pilar p {
    font-size: 0.875rem;
    color: var(--texto-suave);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 3rem;
    }
    .grid-categorias {
      grid-template-columns: repeat(2, 1fr);
    }
    .porque-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .grid-categorias {
      grid-template-columns: 1fr;
    }
  }
</style>
