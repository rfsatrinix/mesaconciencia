---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const categorias = [
  {
    label: 'Macronutrientes',
    href:  '/nutricion/macronutrientes',
    desc:  'Proteínas, carbohidratos y grasas. Los nutrientes que el cuerpo necesita en mayor cantidad.',
  },
  {
    label: 'Micronutrientes',
    href:  '/nutricion/micronutrientes',
    desc:  'Vitaminas y minerales. Necesarios en pequeñas cantidades pero imprescindibles para el metabolismo.',
  },
  {
    label: 'Agua',
    href:  '/nutricion/agua',
    desc:  'El nutriente más abundante del cuerpo. Clave para todos los procesos fisiológicos.',
  },
  {
    label: 'Fibra alimenticia',
    href:  '/nutricion/fibra-alimenticia',
    desc:  'No se digiere pero tiene un papel fundamental en la salud intestinal y metabólica.',
  },
];

const articulos = await getCollection('nutricion', ({ data }) => !data.draft);
---

<Layout
  title="Nutrición"
  description="Macronutrientes, vitaminas, minerales, agua y fibra. Todo lo que necesita tu cuerpo para funcionar, explicado con rigor científico."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <span>Nutrición</span>
      </nav>
      <h1>Nutrición</h1>
      <p class="intro">
        Proteínas, carbohidratos, grasas, vitaminas, minerales, agua y fibra.
        Todo lo que necesita tu cuerpo para funcionar, explicado con rigor científico y sin tecnicismos innecesarios.
      </p>
    </div>

    <section class="seccion">
      <div class="grid-categorias">
        {categorias.map(cat => (
          <a href={cat.href} class="tarjeta tarjeta-categoria">
            <h2>{cat.label}</h2>
            <p>{cat.desc}</p>
            <span class="ver-mas">Ver artículos →</span>
          </a>
        ))}
      </div>
    </section>

    {articulos.length > 0 && (
      <section class="seccion seccion-todos">
        <h2 class="titulo-seccion">Todos los artículos</h2>
        <p class="subtitulo-seccion">Todos los artículos publicados en la sección de Nutrición.</p>
        <div class="grid-articulos">
          {articulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .seccion-todos {
    border-top: 1px solid var(--borde);
  }
</style>
