---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const articulos = await getCollection('nutricion', ({ data }) =>
  !data.draft && data.categoria === 'Grasas o lípidos'
);
---

<Layout
  title="Grasas o lípidos"
  description="Artículos sobre grasas: tipos, ácidos grasos esenciales, fuentes alimentarias y su papel en la salud cardiovascular."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/nutricion">Nutrición</a>
        <span class="sep">›</span>
        <a href="/nutricion/macronutrientes">Macronutrientes</a>
        <span class="sep">›</span>
        <span>Grasas o lípidos</span>
      </nav>
      <h1>Grasas o lípidos</h1>
      <p class="intro">
        Imprescindibles para la absorción de vitaminas liposolubles, la síntesis de hormonas
        y la integridad de las membranas celulares. No todas las grasas son iguales
        ni tienen el mismo efecto sobre la salud.
      </p>
    </div>

    <section class="seccion">
      {articulos.length > 0 ? (
        <div class="grid-articulos">
          {articulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )}
    </section>
  </div>
</Layout>
