---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const articulos = await getCollection('nutricion', ({ data }) =>
  !data.draft && data.categoria === 'Hidratos de carbono'
);
---

<Layout
  title="Hidratos de carbono"
  description="Artículos sobre hidratos de carbono: tipos, índice glucémico, fuentes alimentarias de calidad y necesidades diarias."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/nutricion">Nutrición</a>
        <span class="sep">›</span>
        <a href="/nutricion/macronutrientes">Macronutrientes</a>
        <span class="sep">›</span>
        <span>Hidratos de carbono</span>
      </nav>
      <h1>Hidratos de carbono</h1>
      <p class="intro">
        La principal fuente de energía del organismo. Azúcares simples, almidones complejos,
        índice glucémico y cómo elegir las mejores fuentes dentro de una dieta equilibrada.
      </p>
    </div>

    <section class="seccion">
      {articulos.length > 0 ? (
        <div class="grid-articulos">
          {articulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )}
    </section>
  </div>
</Layout>
