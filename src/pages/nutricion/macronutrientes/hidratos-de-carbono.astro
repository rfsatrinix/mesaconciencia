---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

// Artículo overview de la categoría
const intro = await getEntry('nutricion', 'macronutrientes/hidratos-de-carbono/que-son');
const { Content } = await render(intro!);

// Sub-artículos (excluye el overview)
const subArticulos = (await getCollection('nutricion', ({ data, id }) =>
  !data.draft &&
  id.startsWith('macronutrientes/hidratos-de-carbono/') &&
  id !== 'macronutrientes/hidratos-de-carbono/que-son'
)).sort((a, b) => (a.data.title ?? '').localeCompare(b.data.title ?? '', 'es'));
---

<Layout
  title="Hidratos de carbono"
  description="Qué son los hidratos de carbono, tipos, diferencias entre simples y complejos, su impacto en la glucemia y las mejores fuentes alimentarias."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/nutricion">Nutrición</a>
        <span class="sep">›</span>
        <a href="/nutricion/macronutrientes">Macronutrientes</a>
        <span class="sep">›</span>
        <span>Hidratos de carbono</span>
      </nav>
      <h1>Hidratos de carbono</h1>
    </div>

    <div class="intro-prosa prosa seccion">
      <Content />
    </div>

    {subArticulos.length > 0 && (
      <section class="seccion seccion-tipos">
        <h2 class="titulo-seccion">Profundiza</h2>
        <div class="grid-articulos">
          {subArticulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .seccion-tipos {
    border-top: 1px solid var(--borde);
  }
</style>
