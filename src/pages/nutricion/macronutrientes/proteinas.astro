---
import { getEntry, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const intro = await getEntry('nutricion', 'macronutrientes/proteinas/que-son');
const { Content, headings } = await render(intro!);

const subcategorias = [
  {
    label: 'Aminoácidos esenciales',
    desc:  'Los nueve aminoácidos que el organismo no puede sintetizar y que deben obtenerse obligatoriamente de la dieta.',
    href:  null,
  },
  {
    label: 'Proteínas de origen animal',
    desc:  'Carnes, pescado, huevos y lácteos: perfil de aminoácidos, biodisponibilidad y papel en la dieta.',
    href:  '/nutricion/macronutrientes/proteinas/origen-animal',
  },
  {
    label: 'Proteínas de origen vegetal',
    desc:  'Legumbres, cereales, soja y otros vegetales: cómo cubrir las necesidades proteicas sin productos animales.',
    href:  '/nutricion/macronutrientes/proteinas/origen-vegetal',
  },
];

const migas = [
  { href: '/nutricion', label: 'Nutrición' },
  { href: '/nutricion/macronutrientes', label: 'Macronutrientes' },
];
---

<Layout
  title="Proteínas"
  description={intro!.data.description}
>
  <div class="container seccion">
    <ArticleLayout
      title="Proteínas"
      description={intro!.data.description}
      breadcrumbs={migas}
      headings={headings}
      relacionados={[]}
    >
      <Content />
    </ArticleLayout>

    <section class="seccion seccion-tipos">
      <h2 class="titulo-seccion">Profundiza</h2>
      <div class="grid-articulos">
        {subcategorias.map(sub => sub.href ? (
          <a href={sub.href} class="tarjeta tarjeta-articulo">
            <div class="tarjeta-articulo-inner">
              <h2>{sub.label}</h2>
              <p>{sub.desc}</p>
              <span class="leer-mas">Leer artículo →</span>
            </div>
          </a>
        ) : (
          <div class="tarjeta tarjeta-articulo tarjeta-pronto">
            <div class="tarjeta-articulo-inner">
              <h2>{sub.label}</h2>
              <p>{sub.desc}</p>
              <span class="pronto-badge">Próximamente</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .seccion-tipos {
    border-top: 1px solid var(--borde);
  }

  .tarjeta-pronto {
    opacity: 0.6;
    cursor: default;
    pointer-events: none;
  }

  .pronto-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--texto-suave);
    background: var(--bg-alt);
    border-radius: 4px;
    padding: 0.2em 0.6em;
    margin-top: 0.5rem;
  }
</style>
