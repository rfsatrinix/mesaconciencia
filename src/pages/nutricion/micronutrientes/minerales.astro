---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const articulos = await getCollection('nutricion', ({ data, id }) =>
  !data.draft && id.startsWith('micronutrientes/minerales/')
);
---

<Layout
  title="Minerales"
  description="Artículos sobre minerales y oligoelementos: funciones, necesidades diarias, fuentes alimentarias y señales de deficiencia."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/nutricion">Nutrición</a>
        <span class="sep">›</span>
        <a href="/nutricion/micronutrientes">Micronutrientes</a>
        <span class="sep">›</span>
        <span>Minerales</span>
      </nav>
      <h1>Minerales</h1>
      <p class="intro">
        Los minerales son elementos inorgánicos esenciales para la estructura del organismo
        y la regulación de múltiples procesos fisiológicos. Algunos se necesitan en gramos
        al día (macrominerales) y otros en cantidades de microgramos (oligoelementos).
      </p>
    </div>

    <section class="seccion">
      {articulos.length > 0 ? (
        <div class="grid-articulos">
          {articulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )}
    </section>
  </div>
</Layout>
