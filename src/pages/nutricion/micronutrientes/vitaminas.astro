---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const articulos = await getCollection('nutricion', ({ data, id }) =>
  !data.draft && id.startsWith('micronutrientes/vitaminas/')
);
---

<Layout
  title="Vitaminas"
  description="Artículos sobre vitaminas: funciones, necesidades diarias, fuentes alimentarias y señales de deficiencia."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/nutricion">Nutrición</a>
        <span class="sep">›</span>
        <a href="/nutricion/micronutrientes">Micronutrientes</a>
        <span class="sep">›</span>
        <span>Vitaminas</span>
      </nav>
      <h1>Vitaminas</h1>
      <p class="intro">
        Las vitaminas son compuestos orgánicos que el organismo necesita en pequeñas cantidades
        para regular procesos metabólicos esenciales. La mayoría deben obtenerse de la alimentación
        porque no podemos sintetizarlas, o lo hacemos en cantidades insuficientes.
      </p>
    </div>

    <section class="seccion">
      {articulos.length > 0 ? (
        <div class="grid-articulos">
          {articulos.map(e => (
            <a href={`/nutricion/${e.id}`} class="tarjeta tarjeta-articulo">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                {e.data.description && <p>{e.data.description}</p>}
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )}
    </section>
  </div>
</Layout>
