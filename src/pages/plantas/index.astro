---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entradas = await getCollection('plantas', ({ data }) => !data.draft);
---

<Layout
  title="Plantas medicinales"
  description="Propiedades de las plantas medicinales con evidencia científica. Qué dice la ciencia realmente sobre manzanilla, equinácea, romero y mucho más."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <span>Plantas</span>
      </nav>
      <h1>Plantas medicinales</h1>
      <p class="intro">
        Manzanilla, romero, equinácea, lavanda, tomillo y muchas más.
        Qué dice la evidencia científica sobre sus propiedades reales, sin exageraciones ni negaciones injustificadas.
      </p>
    </div>

    {
      entradas.length > 0 ? (
        <div class="grid-articulos seccion">
          {entradas.map((e) => (
            <a href={`/plantas/${e.id}`} class="tarjeta-articulo tarjeta">
              <div class="tarjeta-articulo-inner">
                <h2>{e.data.title}</h2>
                <p>{e.data.description}</p>
                <span class="leer-mas">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )
    }
  </div>
</Layout>
