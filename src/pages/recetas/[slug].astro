---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entradas = await getCollection('recetas');
  return entradas.map((e) => ({
    params: { slug: e.id },
    props: { entrada: e },
  }));
}

const { entrada } = Astro.props;
const { Content, headings } = await render(entrada);

const todos = await getCollection('recetas', ({ data }) => !data.draft);
const relacionados = todos
  .filter(e => e.id !== entrada.id)
  .filter(e => !entrada.data.categoria || e.data.categoria === entrada.data.categoria)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 3)
  .map(e => ({ id: e.id, coleccion: 'recetas', data: { title: e.data.title, description: e.data.description } }));
---

<Layout title={entrada.data.title} description={entrada.data.description}>
  <div class="container seccion">
    <ArticleLayout
      title={entrada.data.title}
      description={entrada.data.description}
      image={entrada.data.image}
      imageAlt={entrada.data.imageAlt}
      backHref="/recetas"
      backLabel="Recetas"
      headings={headings}
      relacionados={relacionados}
    >
      {(entrada.data.tiempoPrep || entrada.data.raciones) && (
        <div class="datos-receta">
          {entrada.data.tiempoPrep && <span>⏱ Tiempo: {entrada.data.tiempoPrep} min</span>}
          {entrada.data.raciones && <span>🍽 Raciones: {entrada.data.raciones}</span>}
        </div>
      )}
      <Content />
    </ArticleLayout>
  </div>
</Layout>

<style>
  .datos-receta {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-alt);
    border-radius: var(--radio);
    margin-bottom: 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    flex-wrap: wrap;
  }
</style>
