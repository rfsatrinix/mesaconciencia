---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entradas = await getCollection('recetas', ({ data }) => !data.draft);
---

<Layout
  title="Recetas saludables"
  description="Recetas saludables y equilibradas para desayunos, comidas, cenas y postres. Con información nutricional."
>
  <div class="container">
    <div class="cabecera-categoria">
      <nav class="migas">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <span>Recetas</span>
      </nav>
      <h1>Recetas saludables</h1>
      <p class="intro">
        Desayunos, comidas, meriendas, cenas, postres y salsas.
        Recetas equilibradas con información nutricional real, no promesas vacías.
      </p>
    </div>

    {
      entradas.length > 0 ? (
        <div class="grid-articulos seccion">
          {entradas.map((e) => (
            <a href={`/recetas/${e.id}`} class="tarjeta-articulo tarjeta">
              <div class="tarjeta-articulo-inner">
                {e.data.categoria && <span class="etiqueta" style="margin-bottom: 0.75rem; display: inline-block;">{e.data.categoria}</span>}
                <h2>{e.data.title}</h2>
                <p>{e.data.description}</p>
                {e.data.tiempoPrep && <p style="font-size: 0.8rem; color: var(--texto-suave);">⏱ {e.data.tiempoPrep} min · {e.data.raciones ?? '?'} raciones</p>}
                <span class="leer-mas">Ver receta →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="pronto">Contenido en preparación. Próximamente.</p>
      )
    }
  </div>
</Layout>
